{
  "id": "coding",
  "schemaVersion": 2,
  "pipeline": ["PICK_TICKET", "PLAN", "PLAN_REVIEW", "IMPLEMENT", "CODE_REVIEW", "FINALIZE", "COMPLETE"],
  "postComplete": ["LESSON_CAPTURE", "ISSUE_SWEEP"],
  "stages": {
    "PLAN_REVIEW": { "backends": ["lenses", "codex", "agent"] },
    "CODE_REVIEW": { "backends": ["lenses", "codex", "agent"], "maxReviewRounds": 12 },
    "WRITE_TESTS": { "enabled": true, "command": "npm test", "onExhaustion": "plan" },
    "TEST": { "enabled": true, "command": "npm test" },
    "BUILD": { "enabled": false, "command": "npm run build" },
    "VERIFY": { "enabled": false, "startCommand": "npm run dev", "readinessUrl": "http://localhost:3000", "endpoints": [] },
    "LESSON_CAPTURE": { "enabled": false },
    "ISSUE_SWEEP": { "enabled": false },
    "ISSUE_FIX": { "enableCodeReview": false }
  },
  "dirtyFileHandling": "block",
  "branchStrategy": "none",
  "defaults": {
    "maxTicketsPerSession": 0,
    "compactThreshold": "high",
    "reviewBackends": ["lenses", "codex", "agent"],
    "codexReviewBackends": ["lenses"],
    "handoverInterval": 3
  }
}
